{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gustobot.local/schemas/prompt-eval-case.json",
  "title": "GustoBot Prompt Eval Case",
  "type": "object",
  "required": ["case_id", "layer", "input", "expected", "prompt_chain"],
  "additionalProperties": false,
  "properties": {
    "case_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_\\-]+$",
      "description": "全局唯一用例 ID，如 ROUTER-001、E2E-KB-012"
    },
    "layer": {
      "type": "string",
      "enum": [
        "L0_router",
        "L1_guardrails_additional",
        "L1_guardrails_kb",
        "L1_guardrails_kg",
        "L2_kb_router",
        "L2_tool_selection",
        "L3_planner",
        "L3_text2cypher",
        "L3_text2sql",
        "L4_retrieval",
        "L5_generation_kb",
        "L5_generation_summarize",
        "L5_generation_general",
        "E2E"
      ]
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2"],
      "default": "P1"
    },
    "description": {
      "type": "string",
      "description": "人类可读用例说明"
    },
    "input": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": { "type": "string" },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role", "content"],
            "properties": {
              "role": { "type": "string", "enum": ["user", "assistant", "human", "ai"] },
              "content": { "type": "string" }
            }
          }
        },
        "image_path": { "type": "string" },
        "file_path": { "type": "string" },
        "session_id": { "type": "string" },
        "config_overrides": {
          "type": "object",
          "description": "LangGraph configurable 覆盖项",
          "additionalProperties": true
        }
      }
    },
    "expected": {
      "type": "object",
      "properties": {
        "router_type": {
          "type": "string",
          "enum": [
            "general-query",
            "additional-query",
            "kb-query",
            "graphrag-query",
            "text2sql-query",
            "image-query",
            "file-query"
          ]
        },
        "node": {
          "type": "string",
          "description": "LangGraph 节点函数名"
        },
        "guardrails_decision": {
          "type": "string",
          "enum": ["proceed", "end", "planner", "continue"]
        },
        "kb_route": {
          "type": "string",
          "enum": ["local", "external", "hybrid"]
        },
        "kb_tools": {
          "type": "array",
          "items": { "type": "string", "enum": ["postgres", "milvus"] }
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "cypher_query",
              "predefined_cypher",
              "microsoft_graphrag_query",
              "text2sql_query"
            ]
          }
        },
        "sub_tasks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Planner 期望子任务（语义匹配，非字面相等）"
        },
        "cypher_template_name": {
          "type": "string",
          "description": "predefined_cypher 期望模板 key"
        },
        "retrieval": { "$ref": "#/$defs/retrievalExpectation" },
        "generation": { "$ref": "#/$defs/generationRubric" },
        "must_contain": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_not_contain": {
          "type": "array",
          "items": { "type": "string" }
        },
        "response_regex": {
          "type": "string",
          "description": "答案应匹配的正则"
        },
        "structured_output_schema": {
          "type": "object",
          "description": "结构化输出 JSON Schema 片段"
        }
      }
    },
    "prompt_chain": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^P[0-9]{2}$"
      },
      "minItems": 1,
      "description": "期望触发的 Prompt ID 序列，见 PROMPT_EVAL_FRAMEWORK.md §2"
    },
    "data_dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["neo4j", "mysql", "milvus", "postgres", "lightrag", "vision_api", "cogview", "ingest_service", "none"]
      }
    },
    "negative_case": {
      "type": "boolean",
      "default": false,
      "description": "true 表示期望拒答、空检索或降级"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": { "type": "string" },
    "eval_hints": {
      "type": "object",
      "description": "给 Judge LLM 或人工标注员的额外说明",
      "properties": {
        "acceptable_router_types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "semantic_match_subtasks": { "type": "boolean", "default": true },
        "judge_focus": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["routing", "groundedness", "style", "safety", "tool_choice", "completeness"]
          }
        }
      }
    }
  },
  "$defs": {
    "retrievalExpectation": {
      "type": "object",
      "properties": {
        "required_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "optional_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "min_hits": { "type": "integer", "minimum": 0 },
        "max_hits": { "type": "integer", "minimum": 0 },
        "entity_must_appear_in_context": {
          "type": "array",
          "items": { "type": "string" }
        },
        "similarity_min": { "type": "number" },
        "rerank_min": { "type": "number" },
        "postgres_before_milvus": { "type": "boolean" },
        "skip_milvus_if_postgres_hit": { "type": "boolean" },
        "cypher_must_contain": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sql_must_contain": {
          "type": "array",
          "items": { "type": "string" }
        },
        "neo4j_record_min": { "type": "integer", "minimum": 0 }
      }
    },
    "generationRubric": {
      "type": "object",
      "properties": {
        "style": { "type": "string" },
        "language": { "type": "string", "default": "zh-CN" },
        "max_length_chars": { "type": "integer" },
        "must_cite_sources": { "type": "boolean" },
        "grounded_only": { "type": "boolean" },
        "forbid_cooking_steps": { "type": "boolean" },
        "forbid_medical_claims": { "type": "boolean" },
        "require_cooking_steps": { "type": "boolean" },
        "require_statistics_number": { "type": "boolean" },
        "tone": {
          "type": "array",
          "items": { "type": "string" }
        },
        "format": {
          "type": "array",
          "items": { "type": "string" }
        },
        "empty_retrieval_behavior": { "type": "string" }
      }
    }
  }
}
